{
  "name": "prefrontal-desktop",
  "version": "0.1.1",
  "description": "Minimal macOS Electron wrapper for Prefrontal — runs `prefrontal serve` and shows the dashboard.",
  "author": "Tom Fleischer",
  "license": "MIT",
  "private": true,
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --mac"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.prefrontal.desktop",
    "productName": "Prefrontal",
    "afterPack": "afterPack.js",
    "files": [
      "main.js",
      "preload.js",
      "loading.html",
      "settings.html",
      "assets/**"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "assets/icon.icns",
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ]
    },
    "dmg": {
      "title": "${productName} ${version}"
    }
  }
}
