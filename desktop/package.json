{
  "name": "prefrontal-desktop",
  "version": "0.1.0",
  "description": "Minimal macOS Electron wrapper for Prefrontal — runs `prefrontal serve` and shows the dashboard.",
  "author": "Tom Fleischer",
  "license": "MIT",
  "private": true,
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --mac"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.morningstatic.prefrontal.desktop",
    "productName": "Prefrontal",
    "files": [
      "main.js",
      "preload.js",
      "loading.html",
      "assets/**"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "assets/icon.png",
      "target": [
        "dmg"
      ]
    }
  }
}
