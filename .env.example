# Prefrontal configuration.
#
# Copy this file to `.env` and adjust. Every value has a safe default, so an
# empty `.env` still boots — but before exposing the webhook listener beyond
# localhost you SHOULD provision at least one user (`prefrontal user add
# <handle> --operator`) and authenticate with that user's token.

# --- Memory layer ---------------------------------------------------------
# Path to the SQLite database that holds episodes, patterns, and coaching state.
PREFRONTAL_DB_PATH=prefrontal.db

# --- Webhook listener -----------------------------------------------------
# Host/port the FastAPI listener binds to.
PREFRONTAL_HOST=0.0.0.0
PREFRONTAL_PORT=8000

# Multi-tenant auth: the `X-Prefrontal-Token` header carries a PER-USER token
# (minted by `prefrontal user add`), resolved to a user that scopes the request.
#
# PREFRONTAL_WEBHOOK_SECRET is now only a *bootstrap operator token*: a request
# bearing it resolves to the first operator user, so a fresh deployment can
# authenticate before per-user tokens are provisioned. Leave blank once real
# tokens exist.
PREFRONTAL_WEBHOOK_SECRET=
#
# PREFRONTAL_DEFAULT_USER: handle that tokenless requests resolve to (the
# single-user / trusted-LAN convenience mode). Leave blank to always require a
# token. Only safe on a fully trusted local network.
PREFRONTAL_DEFAULT_USER=

# PREFRONTAL_TIMEZONE: IANA name of your home timezone (e.g. America/New_York).
# Used only to interpret calendar times that arrive WITHOUT their own zone — a
# floating/naive ICS time or a manual commitment. Events carrying an offset or a
# TZID keep their own zone. Defaults to UTC; set it to your actual zone so
# unzoned events don't show up hours off.
PREFRONTAL_TIMEZONE=America/New_York

# Optional: friendly display pills for calendars on the dashboard, so each
# commitment shows which calendar it belongs to. Format is a comma-separated list
# of `feed=label:color` — `feed` is the calendar feed slug (the external_id
# namespace a synced commitment carries, e.g. personal/work/outlook), `label` is
# the text shown on the pill, and `color` is any CSS color. The `:color` part is
# optional. Feeds omitted here keep their default label with no color.
# Example: PREFRONTAL_CALENDAR_LABELS=personal=Personal:blue,work=Vistar:orange,outlook=T-Mobile:magenta
PREFRONTAL_CALENDAR_LABELS=

# --- Todo suggestion time windows ----------------------------------------
# When a todo may be suggested into free time (the widget's "what fits now" and
# the briefing's spare-time picks). Local wall-clock; times are per your
# PREFRONTAL_TIMEZONE. Both are optional — blank uses the built-in defaults, and
# coaching-state (todo_offzone / todo_window:<key>) overrides these per user.
#
# PREFRONTAL_TODO_OFFZONE: a hard band nothing is ever suggested inside (an
# overnight window wraps midnight). Default 22:00-06:00.
PREFRONTAL_TODO_OFFZONE=22:00-06:00
# PREFRONTAL_TODO_WINDOWS: narrower windows per todo *domain*, *category*, or
# *source*, as a comma-separated list of `key=HH:MM-HH:MM`. A todo's window
# resolves per-todo override → domain → category → source → default (the
# off-zone's complement, so an uncategorized "make coffee" is offerable any
# waking hour). Built-in category defaults exist for
# work/finance/admin/communication/errands/learning/health/home.
# Example: PREFRONTAL_TODO_WINDOWS=work=09:00-17:00,finance=09:00-18:00,home=06:00-22:00
PREFRONTAL_TODO_WINDOWS=
# PREFRONTAL_ACCOUNT_DOMAINS: the work/life guardrail — map a mail account to a
# life *domain* (work / home / …), comma-separated `account=domain`. A todo
# created from that inbox inherits the domain, which resolves to the domain's
# time band above and *outranks* the triage category — so a work email that
# triages as "communication" is still held to work hours, never squeezed into a
# home evening. Empty (default) → no domain stamped; scheduling is unchanged.
# Example: PREFRONTAL_ACCOUNT_DOMAINS=work=work,corp=work,personal=home
PREFRONTAL_ACCOUNT_DOMAINS=

# --- Challenge-area modules ----------------------------------------------
# Comma-separated list of modules to enable. Leave blank to enable ALL of them
# (the default), since ADHD presents differently for everyone and modules are
# opt-out rather than opt-in. Available: time_blindness, task_paralysis,
# hyperfocus, impulsivity, location_anchor, trip_tracking, self_care.
# (trip_tracking passively logs undeclared round trips from location pings once a
# home coordinate is set via POST /webhooks/home, then asks you to label them and
# say how they went — see docs and the README module table.)
# (self_care is the odd one out: even when enabled it stays quiet until you set
# the `self_care` coaching key to `on` — the "have you eaten?" meal check and the
# "drink some water" check, each with a daily target.)
# Example: PREFRONTAL_MODULES=time_blindness,hyperfocus
PREFRONTAL_MODULES=

# Context Packs — life-context layers (what life you're managing), orthogonal to
# the challenge modules above. A pack switches on a relevant subset of modules and
# seeds domain vocabulary + time-window defaults. Unlike modules, packs are OFF by
# default (empty = none) — a pack is an explicit opt-in. Comma-separated keys; when
# two packs set the same default the earlier-listed one wins. Run `prefrontal packs
# -v` to see each pack's composition. Available: parent.
# (The `parent` pack also turns on the focus-balance guardrail: it seeds weekly
# out-of-home targets `focus_target:home` / `focus_target:personal` and the
# `focus_balance_nudge` flag into coaching state. Add `focus_target:<domain>` for
# shop/work/etc., or clear the flag to silence the nudge — see `GET /balance` and
# `prefrontal balance` for the rollup those targets are measured against.)
# Example: PREFRONTAL_PACKS=parent
PREFRONTAL_PACKS=

# --- n8n integration ------------------------------------------------------
# Outbound: the n8n webhook URL Prefrontal POSTs events to. Leave blank and
# the n8n client runs in no-op/log mode (nothing leaves the box).
N8N_WEBHOOK_URL=

# Optional token sent to n8n as the `X-Prefrontal-Token` header on outbound calls.
N8N_WEBHOOK_TOKEN=

# Workflow sync (`prefrontal n8n push`, run by deploy/update.sh so the Update
# button also updates n8n). Point these at n8n's Public REST API to upsert the
# deploy/n8n/*.json templates into the running n8n on every update — idempotent
# (matched by workflow name, so re-runs update in place, no duplicates). Leave
# either blank and the sync is a clean no-op: nothing is pushed and an update
# never fails for lack of n8n. Create the key in n8n: Settings → n8n API. See
# docs/n8n-sync.md. Use 127.0.0.1 (not localhost) — see the deployment gotcha.
N8N_API_URL=
N8N_API_KEY=

# --- Delivery layer (native publishing: ntfy / Pushover / TTS) ------------
# Operator DEFAULT delivery targets for the native delivery client
# (`prefrontal coach --deliver`, prefrontal.integrations.delivery). Per-user
# targets in coaching_state (`ntfy_topic`, `ntfy_server`, `ntfy_token`,
# `pushover_user_key`, `pushover_token`, `tts_enabled`) override these, so a
# multi-tenant box configures one default here and only overrides per user.
# Local-first: leave everything blank and the client no-ops (nothing leaves the
# box) — delivery via the n8n workflows keeps working unchanged.
#
# ntfy (preferred — supports the inline one-tap action buttons). NTFY_SERVER
# defaults to the public ntfy.sh; point it at a self-hosted server to stay local.
NTFY_SERVER=https://ntfy.sh
NTFY_TOPIC=
# Optional bearer token for a protected ntfy topic/server.
NTFY_TOKEN=
#
# Pushover (fallback — no inline buttons; the first action rides as a tap URL).
PUSHOVER_TOKEN=
PUSHOVER_USER_KEY=
#
# Speak `voice`-channel nudges aloud on the host via macOS `say`. Off by default
# (only useful when you're at the machine); '1'/'true' to enable.
PREFRONTAL_TTS_ENABLED=

# --- Ollama (local inference for the summarizer) --------------------------
# Local Ollama server the `prefrontal summarize` command generates with. Stays
# on the host (local first). Pull the model first, e.g. `ollama pull llama3.1:8b`.
#
# Model choice by available RAM (the summary task is light; bigger = nicer prose):
#   ~8GB   llama3.2:3b
#   ~16GB  llama3.1:8b  (default)  /  qwen2.5:7b
#   24GB+  qwen2.5:14b  /  gemma2:9b
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# --- Anthropic / Claude (optional) ----------------------------------------
# Opt-in cloud reasoning for the heavier-reasoning agents. Local-first by
# default: leave ANTHROPIC_API_KEY blank and every agent uses the local Ollama
# model above. Set a key (and `pip install -e '.[anthropic]'`) to enable Claude.
# The key is only ever sent on outbound calls to Anthropic.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
# Which *agents* prefer Claude (when a key is set), comma-separated. Everything
# else stays local. Selectable: assistant, summarizer, briefing, sensor, triage.
# Unset keeps the historical default (only the dashboard `assistant`); `all`
# opts every agent in; an empty value opts them all back to local. Each agent
# falls back to Ollama if Claude is unavailable or a call fails.
ANTHROPIC_AGENTS=assistant

# --- Geocoding ------------------------------------------------------------
# Resolve a commitment's free-text location to coordinates for the departure
# reminder's travel estimate. This is the only outbound network call Prefrontal
# makes, so it is OPT-IN: flip the `geocoding_enabled` coaching-state flag to '1'
# (default '0'). Until then, only curated `places` (POST /places) and the cache
# are used. The endpoint below is Nominatim-compatible; its usage policy needs an
# identifying User-Agent and ~1 req/s, so keep volume low (the cache handles it).
GEOCODER_URL=https://nominatim.openstreetmap.org/search
GEOCODER_USER_AGENT=Prefrontal/0.1 (https://github.com/jawsthegame/prefrontal)

# --- Mail ingestion -------------------------------------------------------
# Per-account retention policy for triaged email. Format: name=policy pairs.
#   full    — store subject, sender, snippet, and body (fine for accounts you own)
#   signals — store ONLY subject + sender + the triage verdict; bodies are
#             dropped before storage and never sent to the model (use for
#             locked-down / corporate accounts where you carry across only
#             derived signals, not content)
# Accounts not listed here use PREFRONTAL_MAIL_DEFAULT_POLICY below.
# Example: PREFRONTAL_MAIL_ACCOUNTS=personal=full,work=full,corp=signals
PREFRONTAL_MAIL_ACCOUNTS=

# Policy for any account not named above. Defaults to `signals` (conservative:
# an unconfigured account never stores bodies by accident).
PREFRONTAL_MAIL_DEFAULT_POLICY=signals

# Optional: friendly display pills for the accounts above, so a todo ingested
# from mail shows which inbox it came from on the dashboard. Format is a
# comma-separated list of `account=label:color` — the account is the logical
# name from PREFRONTAL_MAIL_ACCOUNTS, `label` is the text shown on the pill, and
# `color` is any CSS color. The `:color` part is optional. Accounts omitted here
# show no pill.
# Example: PREFRONTAL_ACCOUNT_LABELS=work=Vistar:orange,outlook=t-mobile:magenta
PREFRONTAL_ACCOUNT_LABELS=

# Optional: IMAP credentials for the built-in `prefrontal mail fetch` path (a
# no-n8n fetcher using stdlib imaplib; Gmail works with an app password). Most
# setups instead let n8n's Gmail node fetch and POST to /webhooks/mail/sync, in
# which case these stay blank. Per account, suffix with the UPPERCASED account
# name, e.g. for account `personal`:
#   MAIL_IMAP_HOST_PERSONAL=imap.gmail.com
#   MAIL_IMAP_USER_PERSONAL=you@gmail.com
#   MAIL_IMAP_PASSWORD_PERSONAL=your-app-password
# Gmail accounts only consider mail Gmail flagged Important (its X-GM-RAW
# "is:important" search). On by default for Gmail; override per account with:
#   MAIL_IMAP_IMPORTANT_ONLY_PERSONAL=false

# Triage learns from dropped intake todos: when you drop a todo that mail intake
# created, the originating email becomes a "this didn't need action" example
# folded into the next sync's triage prompt. A drop is ambiguous (it can also be
# avoidance), so a drop only counts as a correction when it's quick (dropped
# within QUICK_DROP_DAYS of arriving) or the sender has been dropped
# REPEAT_THRESHOLD+ times. Inspect/curate with `prefrontal mail learned`.
PREFRONTAL_TRIAGE_QUICK_DROP_DAYS=2
PREFRONTAL_TRIAGE_REPEAT_THRESHOLD=2

# Triage agent (POST /webhooks/n8n, POST /triage): classify an inbound signal and
# route it (dated event → commitment, task → todo, noise → dropped). LLM refines
# only the ambiguous cases with a heuristic fallback; set LLM=false for pure
# heuristic. DROP: below this confidence a "noise" verdict is surfaced not dropped.
PREFRONTAL_TRIAGE_LLM=true
PREFRONTAL_TRIAGE_DROP=0

# --- Google sign-in for the web pages (dashboard/family) ------------------
# Optional. Lets you sign into the dashboard with Google instead of pasting a
# token. The automated clients (n8n, iOS Shortcuts, the widget) keep using
# per-user X-Prefrontal-Token tokens regardless — OAuth is browser-login only.
#
# Setup: (1) `tailscale serve --bg 8000` so the app is reachable over https on
# your tailnet name; (2) Google Cloud Console → Credentials → OAuth client ID
# (Web application); set the redirect URI to <OAUTH_BASE_URL>/auth/google/callback
# and add yourself as a test user on the consent screen.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Public https origin the app is served at (no trailing slash).
OAUTH_BASE_URL=https://agent-1.tail8b0a.ts.net
# Random secret that signs the browser session cookie (e.g. `openssl rand -hex 32`).
SESSION_SECRET=
# Allowlist: only these Google emails may sign in, each mapped to a user handle.
GOOGLE_OAUTH_ALLOWED=tfleischer@gmail.com=tom

# --- Remote update / restart --------------------------------------------------
# Let an operator pull the latest code and restart the service over HTTP
# (POST /admin/update, /admin/restart) instead of SSHing in. Powerful — it runs
# whatever is on the deployed branch — so it's OFF until you set this. The CLI
# (`prefrontal update` / `restart`) runs on-host and works regardless.
PREFRONTAL_SELF_UPDATE=off
# Where the update runs git (defaults to the repo root the package lives in).
# PREFRONTAL_REPO_DIR=/Users/tom/prefrontal
# Override the update command (default: bash deploy/update.sh — edit that script
# to match your venv/paths). Override the restart for non-launchd hosts.
# PREFRONTAL_UPDATE_CMD=bash deploy/update.sh
# PREFRONTAL_RESTART_CMD=launchctl kickstart -k gui/501/com.morningstatic.prefrontal
