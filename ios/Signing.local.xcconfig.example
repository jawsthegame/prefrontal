// Copy this to `Signing.local.xcconfig` (same folder) and set your Team ID.
// That copy is git-ignored, so it's never committed and survives both a fresh
// clone and `xcodegen generate` — set it once and you never re-enter the team.
//
//     cp ios/Signing.local.xcconfig.example ios/Signing.local.xcconfig
//
// Find your Team ID in Xcode ▸ Settings ▸ Accounts ▸ (your team), or at
// developer.apple.com ▸ Membership.

DEVELOPMENT_TEAM = YOUR_TEAM_ID

// Native APNs push (paid Apple Developer account only). Uncomment to sign with
// the push-enabled entitlements (adds `aps-environment`); the default is the
// free-signing file without it. Regeneration-proof — XcodeGen only references
// the file, so `xcodegen generate` never strips the capability. After enabling,
// run `cd ios && xcodegen generate`, then also configure APNS_* on the server.
// PREFRONTAL_ENTITLEMENTS = Prefrontal/Prefrontal.push.entitlements
