<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>com.apple.security.application-groups</key>
	<array>
		<string>group.com.morningstatic.prefrontal</string>
	</array>
	<!-- Shared Keychain access group for the bearer token (#496), read by both
	     the app and the widget. Kept as the sole entry so a keychain write with
	     no explicit access group defaults to it (no hard-coded team prefix).
	     $(AppIdentifierPrefix) expands to the team's prefix at build time. -->
	<key>keychain-access-groups</key>
	<array>
		<string>$(AppIdentifierPrefix)com.morningstatic.prefrontal.shared</string>
	</array>
	<!-- Native push (APNs) is intentionally NOT declared here. The
	     `aps-environment` entitlement requires a paid Apple Developer account;
	     a free "Personal Team" can't mint a profile that includes it, which
	     blocks the whole app from signing. Without it, delivery falls back to
	     ntfy server-side, so the app still works on free signing.

	     To use native push (paid tier only), DON'T add the capability in Xcode's
	     UI (it lands in the git-ignored, regenerated .xcodeproj and is lost on
	     `xcodegen generate`). Instead point PREFRONTAL_ENTITLEMENTS at the
	     sibling Prefrontal.push.entitlements via your git-ignored
	     Signing.local.xcconfig — regeneration-proof. See ios/README.md. -->
</dict>
</plist>
