<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>com.apple.security.application-groups</key>
	<array>
		<string>group.com.morningstatic.prefrontal</string>
	</array>
	<!-- Native push (APNs) is intentionally NOT declared here. The
	     `aps-environment` entitlement requires a paid Apple Developer account;
	     a free "Personal Team" can't mint a profile that includes it, which
	     blocks the whole app from signing. To use native push (paid tier only),
	     add the Push Notifications capability in Xcode ▸ Signing & Capabilities
	     — it writes `aps-environment` back into this file. Without it, delivery
	     falls back to ntfy server-side, so the app still works. See ios/README.md. -->
</dict>
</plist>
