<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Same watch-local App Group as the watch app, so this complication reads
	     the WatchGlance the app cached. -->
	<key>com.apple.security.application-groups</key>
	<array>
		<string>group.com.morningstatic.prefrontal.watch</string>
	</array>
</dict>
</plist>
