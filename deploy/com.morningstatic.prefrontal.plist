<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  launchd agent that runs `prefrontal serve` always-on.

  Install:
    cp deploy/com.morningstatic.prefrontal.plist ~/Library/LaunchAgents/
    # then edit the paths below to match your username and install location
    launchctl load -w ~/Library/LaunchAgents/com.morningstatic.prefrontal.plist

  WorkingDirectory must be the repo root so the `.env` next to it is loaded.
-->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.morningstatic.prefrontal</string>

    <key>ProgramArguments</key>
    <array>
        <string>/Users/tom/src/prefrontal/.venv/bin/prefrontal</string>
        <string>serve</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/tom/src/prefrontal</string>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <!-- Prefrontal holds one SQLite connection (db + -wal + -shm = 3 fds) per
         worker thread. The macOS default soft limit of 256 is far too low and
         the process can exhaust fds, 500ing DB endpoints with "unable to open
         database file". Raise it well clear of steady state. (The store also
         reaps dead worker threads' connections, so this is headroom, not a
         band-aid for an unbounded leak.) -->
    <key>SoftResourceLimits</key>
    <dict>
        <key>NumberOfFiles</key>
        <integer>4096</integer>
    </dict>
    <key>HardResourceLimits</key>
    <dict>
        <key>NumberOfFiles</key>
        <integer>8192</integer>
    </dict>

    <key>StandardOutPath</key>
    <string>/Users/tom/Library/Logs/prefrontal.out.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/tom/Library/Logs/prefrontal.err.log</string>

    <key>EnvironmentVariables</key>
    <dict>
        <!-- Homebrew (Apple Silicon) on PATH so child processes resolve as expected. -->
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
    </dict>
</dict>
</plist>
